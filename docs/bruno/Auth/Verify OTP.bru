meta {
  name: Verify OTP
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/v1/auth/otp/verify
  body: json
  auth: none
}

body:json {
  {
    "email": "user@example.com",
    "code": "123456"
  }
}

script:post-response {
  if (res.getStatus() === 200) {
    bru.setEnvVar("token", res.getBody().token);
    bru.setEnvVar("refresh_token", res.getBody().refresh_token);
  }
}
